---
import Section from "@/components/ui/Section.astro";
import { FAQ_ITEMS } from "@/shared/data/constants";
---

<Section theme="cream">
  <div class="mx-auto max-w-3xl">
    <h2 class="text-center text-3xl font-semibold tracking-tight text-[var(--cn-ink)]">
      Dúvidas Frequentes
    </h2>
    <div class="mt-12 space-y-3">
      {
        FAQ_ITEMS.map((faq) => (
          <details class="faq-item group rounded-2xl border border-black/5 bg-white">
            <summary class="faq-summary flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5">
              <h3 class="font-medium text-[var(--cn-ink)]">{faq.q}</h3>
              <span class="faq-icon flex-shrink-0 text-[var(--cn-terracotta)]">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <div class="faq-body px-6 pb-5">
              <p class="text-sm leading-relaxed text-black/70">{faq.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</Section>

<style>
  /* Hide the native marker in all browsers */
  .faq-summary::-webkit-details-marker {
    display: none;
  }

  /* Rotate chevron when open */
  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-icon {
    transition: transform 0.3s ease;
  }

  /* Subtle hover on summary */
  .faq-summary:hover h3 {
    color: var(--cn-terracotta);
  }

  /* Animated reveal using a max-height trick */
  .faq-body {
    overflow: hidden;
    animation: faq-open 0.3s ease forwards;
  }

  @keyframes faq-open {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Subtle border highlight when open */
  .faq-item[open] {
    border-color: rgba(0, 0, 0, 0.1);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
  }
</style>
