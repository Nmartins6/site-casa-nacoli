---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/ui/Section.astro";
import PageHeader from "@/components/PageHeader.astro";
import Button from "@/components/ui/Button.astro";
import { SITE } from "@/shared/config/site";

const title = `Sobre | ${SITE.name}`;
const description =
  "Conheça a história e o processo da Casa Nacoli, gráfica artesanal em Lajeado/RS.";
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={`${import.meta.env.BASE_URL}sobre`}
>
  <PageHeader title="Sobre a Casa Nacoli" description={description} containerClass="max-w-7xl" />

  <Section containerClass="max-w-screen-2xl">
    <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
      <div class="reveal reveal-left lg:col-span-7">
        <div
          class="overflow-hidden rounded-3xl shadow-2xl shadow-black/10 transition-transform duration-500 hover:-translate-y-1"
        >
          <img
            src={`${import.meta.env.BASE_URL}images/products/papelaria-personalizada/papelaria-personalizada.png`}
            alt="Processo Artesanal Casa Nacoli"
            class="aspect-video w-full object-cover transition-transform duration-700 hover:scale-105"
          />
        </div>
      </div>
      <div class="reveal reveal-right lg:col-span-5 lg:pl-8" style="--delay: 0.08s;">
        <h2 class="text-4xl font-semibold tracking-tight text-[var(--cn-ink)] md:text-5xl">
          Artesanal e Independente
        </h2>
        <div class="mt-8 text-xl text-black/70 leading-relaxed space-y-6">
          <p>
            Somos um estúdio de design e gráfica em Lajeado, Rio Grande do Sul. Fugimos da produção
            em massa para focar nos detalhes que fazem a diferença: a textura do papel, a escolha da
            tipografia, o acabamento manual.
          </p>
          <p>
            Nosso processo combina técnicas tradicionais de impressão com design contemporâneo.
            Nosso objetivo é encantar através do toque e da visão.
          </p>
        </div>
        <div class="mt-10">
          <Button href={`${import.meta.env.BASE_URL}catalogo`} size="lg"
            >Explorar nosso catálogo</Button
          >
        </div>
      </div>
    </div>
  </Section>

  <Section theme="cream" containerClass="max-w-screen-2xl">
    <div class="reveal reveal-up mb-20 text-center">
      <h2 class="text-4xl font-semibold tracking-tight text-[var(--cn-ink)] md:text-5xl">
        O Processo Artesanal
      </h2>
      <p class="mx-auto mt-6 max-w-3xl text-xl text-black/60">
        Cada projeto passa por um ciclo de cuidado e atenção, garantindo um resultado único e com
        alma.
      </p>
    </div>

    <div class="grid gap-10 md:grid-cols-3">
      {
        [
          {
            title: "Criação & Design",
            desc: "Tudo começa no papel (ou no pixel). Criamos layouts que refletem a identidade e o propósito de cada cliente.",
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-8"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
          },
          {
            title: "Impressão Curada",
            desc: "Escolhemos os melhores materiais e técnicas de impressão que valorizam a ideia do cliente.",
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-8"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z"/></svg>`,
          },
          {
            title: "Acabamento Manual",
            desc: "O toque final é dado à mão: cortes precisos, colagem delicada e embalagem com carinho.",
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-8"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5zM16 8L2 22M17.5 15H9"/></svg>`,
          },
        ].map((step, index) => (
          <div
            class="group relative reveal reveal-up overflow-hidden rounded-3xl bg-white p-12 transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl"
            style={`--delay: ${0.05 + index * 0.06}s;`}
          >
            <div class="flex size-16 items-center justify-center rounded-2xl bg-[var(--cn-sky)]/10 text-[var(--cn-ink)] transition-colors group-hover:bg-[var(--cn-terracotta)] group-hover:text-white">
              <Fragment set:html={step.icon} />
            </div>
            <h3 class="mt-8 text-2xl font-semibold text-[var(--cn-ink)]">{step.title}</h3>
            <p class="mt-4 text-lg text-black/60 leading-relaxed">{step.desc}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <Section containerClass="max-w-screen-2xl">
    <div class="text-center">
      <h2 class="text-4xl font-semibold tracking-tight text-[var(--cn-ink)] md:text-5xl">
        Valorizamos o tempo e a calma
      </h2>
      <div
        class="reveal reveal-up mt-10 max-w-4xl mx-auto space-y-8 text-xl text-black/70 leading-relaxed"
      >
        <p>
          Acreditamos que o que é feito devagar tem mais valor. Cada projeto é desenvolvido com
          atenção individual, garantindo que o resultado final reflita a essência de quem o
          encomendou.
        </p>
        <p>
          Nossa curadoria de materiais e processos é pensada para quem busca algo além do comercial.
          Buscamos o extraordinário no simples, o detalhe que faz alguém parar e sentir.
        </p>
      </div>

      <div
        class="reveal reveal-up mt-16 overflow-hidden rounded-3xl shadow-2xl"
        style="--delay: 0.08s;"
      >
        <img
          src={`${import.meta.env.BASE_URL}images/products/brindes-corporativos/brindes-corporativos-1.webp`}
          alt="Detalhes que importam"
          class="h-[500px] w-full object-cover"
        />
      </div>
    </div>
  </Section>

  <Section theme="white" class="pb-32" containerClass="max-w-screen-2xl">
    <div class="reveal reveal-up mb-20 text-center">
      <h2 class="text-4xl font-semibold tracking-tight text-[var(--cn-ink)] md:text-5xl">
        Nossos Valores
      </h2>
    </div>

    <div class="grid gap-12 sm:grid-cols-3">
      {
        [
          {
            title: "Qualidade Artesanal",
            desc: "Cuidado genuíno em cada etapa, do design ao acabamento manual.",
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>`,
          },
          {
            title: "Atendimento Próximo",
            desc: "Conversa direta e transparente para entender e personalizar cada desejo.",
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
          },
          {
            title: "Design com Propósito",
            desc: "Estética que comunica a essência da sua marca ou momento especial.",
            icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>`,
          },
        ].map((valor, index) => (
          <div
            class="flex flex-col reveal reveal-up items-center text-center"
            style={`--delay: ${0.05 + index * 0.06}s;`}
          >
            <div class="flex size-20 items-center justify-center rounded-3xl bg-[var(--cn-cream)] text-[var(--cn-terracotta)] shadow-lg shadow-[var(--cn-terracotta)]/5">
              <Fragment set:html={valor.icon} />
            </div>
            <h3 class="mt-8 text-2xl font-semibold text-[var(--cn-ink)]">{valor.title}</h3>
            <p class="mt-4 max-w-xs text-lg text-black/60 leading-relaxed">{valor.desc}</p>
          </div>
        ))
      }
    </div>
  </Section>
</BaseLayout>
