---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { SITE } from "@/shared/config/site";
import { buildWhatsAppLink } from "@/shared/lib/whatsapp";

const title = `Contato | ${SITE.name}`;
const description =
  "Entre em contato com a Casa Nacoli. WhatsApp, email e localização em Lajeado/RS.";

const whatsappHref = buildWhatsAppLink(
  "Olá! Vim pelo site da Casa Nacoli e gostaria de tirar uma dúvida.",
);
---

<BaseLayout title={title} description={description} canonicalPath="/contato">
  <PageHeader
    title="Vamos criar algo juntos?"
    description="Estamos à disposição para tirar dúvidas, fazer orçamentos ou agendar uma visita ao estúdio."
  />

  <div class="mt-12 grid gap-6 sm:grid-cols-3 text-left">
    <div
      class="reveal reveal-up rounded-2xl border border-black/5 bg-white p-6 shadow-sm transition-transform duration-500 hover:-translate-y-1 sm:p-8"
    >
      <div
        class="flex size-12 items-center justify-center rounded-xl bg-[var(--cn-cream)] text-[var(--cn-ink)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          fill="currentColor"
          viewBox="0 0 256 256"
          ><path
            d="M187.58,144.84l-32-16a8,8,0,0,0-8,.5l-14.69,9.8a40.55,40.55,0,0,1-16-16l9.8-14.69a8,8,0,0,0,.5-8l-16-32A8,8,0,0,0,104,64a40,40,0,0,0-40,40,88.1,88.1,0,0,0,88,88,40,40,0,0,0,40-40A8,8,0,0,0,187.58,144.84ZM152,176a72.08,72.08,0,0,1-72-72A24,24,0,0,1,99.29,80.46l11.48,23L100.8,118.42a8,8,0,0,0-.73,7.51,56.47,56.47,0,0,0,30,30,8,8,0,0,0,7.51-.73l14.95-9.95,23,11.48A24,24,0,0,1,152,176ZM128,24A104,104,0,0,0,36.18,176.88L24.83,210.93a16,16,0,0,0,20.24,20.24l34.05-11.35A104,104,0,1,0,128,24Zm0,192a87.87,87.87,0,0,1-44.06-11.81,8,8,0,0,0-6.54-.67L40,216,52.47,178.6a8,8,0,0,0-.66-6.54A88,88,0,1,1,128,216Z"
          ></path></svg
        >
      </div>
      <h3 class="mt-4 font-semibold text-[var(--cn-ink)]">WhatsApp</h3>
      <p class="mt-2 text-sm text-black/60">A forma mais rápida de falar com a gente.</p>
      <a
        href={whatsappHref}
        target="_blank"
        class="mt-4 inline-block py-2 text-sm font-medium text-[var(--cn-terracotta)] hover:underline"
      >
        {SITE.contact.whatsapp}
      </a>
    </div>

    <div
      class="reveal reveal-up rounded-2xl border border-black/5 bg-white p-6 shadow-sm transition-transform duration-500 hover:-translate-y-1 sm:p-8"
      style="--delay: 0.08s;"
    >
      <div
        class="flex size-12 items-center justify-center rounded-xl bg-[var(--cn-cream)] text-[var(--cn-ink)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          fill="currentColor"
          viewBox="0 0 256 256"
          ><path
            d="M224,48H32a8,8,0,0,0-8,8V192a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A8,8,0,0,0,224,48Zm-8,16V67.29l-83.88,55.92a8,8,0,0,1-8.24,0L40,67.29V64Zm0,128H40V86.54l82.8,55.19a16,16,0,0,0,10.4,0L216,86.54V192Z"
          ></path></svg
        >
      </div>
      <h3 class="mt-4 font-semibold text-[var(--cn-ink)]">Email</h3>
      <p class="mt-2 text-sm text-black/60">Para orçamentos detalhados ou parcerias.</p>
      <a
        href={`mailto:${SITE.contact.email}`}
        class="mt-4 inline-block py-2 text-sm font-medium text-[var(--cn-terracotta)] hover:underline"
      >
        {SITE.contact.email}
      </a>
    </div>

    <div
      class="reveal reveal-up rounded-2xl border border-black/5 bg-white p-6 shadow-sm transition-transform duration-500 hover:-translate-y-1 sm:p-8"
      style="--delay: 0.16s;"
    >
      <div
        class="flex size-12 items-center justify-center rounded-xl bg-[var(--cn-cream)] text-[var(--cn-ink)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          fill="currentColor"
          viewBox="0 0 256 256"
          ><path
            d="M128,64a40,40,0,1,0,40,40A40,40,0,0,0,128,64Zm0,64a24,24,0,1,1,24-24A24,24,0,0,1,128,128Zm0-112a88.1,88.1,0,0,0-88,88c0,31.4,14.51,64.68,42,96.25a254.19,254.19,0,0,0,41.88,38.92,8,8,0,0,0,8.24,0A254.19,254.19,0,0,0,174,200.25c27.45-31.57,42-64.85,42-96.25A88.1,88.1,0,0,0,128,16Zm0,206c-16.53-13-72-60.75-72-118a72,72,0,0,1,144,0C200,161.23,144.53,209,128,222Z"
          ></path></svg
        >
      </div>
      <h3 class="mt-4 font-semibold text-[var(--cn-ink)]">Localização</h3>
      <p class="mt-2 text-sm text-black/60">
        {SITE.address.city}, {SITE.address.state}.<br />
        Atendimento com hora marcada.
      </p>
      <a
        href="https://maps.google.com"
        target="_blank"
        class="mt-4 inline-block py-2 text-sm font-medium text-[var(--cn-terracotta)] hover:underline"
      >
        Ver no mapa (Breve)
      </a>
    </div>
  </div>
</BaseLayout>
